#!/usr/bin/env bash
# Bootstrap a new project in the Obsidian vault.
# Creates the full folder structure + metadata stub.
# Idempotent — safe to run on existing projects (won't overwrite).
#
# Usage: bootstrap <project-name> [repo-url]
# Example: bootstrap my-project https://github.com/org/my-project

set -euo pipefail

PROJECT="${1:?Usage: bootstrap <project-name> [repo-url]}"
REPO_URL="${2:-}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
OBSIDIAN="${SCRIPT_DIR}/obsidian"

if [[ ! -x "$OBSIDIAN" ]]; then
  echo "ERROR: obsidian CLI not found at ${SCRIPT_DIR}/obsidian" >&2
  exit 1
fi

# Check if a note exists — returns 0 if found, 1 if not.
# The obsidian CLI returns JSON error bodies on 404, so we check exit code, not output.
note_exists() {
  "$OBSIDIAN" read "$1" >/dev/null 2>&1
}

# Check if project has been bootstrapped (metadata file = bootstrap marker)
note_exists "${PROJECT}/${PROJECT}_metadata.md" && metadata_exists=true || metadata_exists=false

echo "Bootstrapping project: ${PROJECT}"

# Scaffold every folder by writing a .gitkeep-style placeholder.
# Obsidian creates folders implicitly when notes are written.
# Skips folders that already have content.

folders=(
  "Architecture/Decisions"
  "Backlog/Issues/Open"
  "Backlog/Issues/Closed"
  "Insights"
  "RFCs/01 - Ideas"
  "RFCs/02 - Designs"
  "RFCs/03 - Active"
  "RFCs/04 - Complete"
  "RFCs/05 - Superseded"
  "RFCs/06 - Deprecated"
  "Sessions"
)

created=0
for folder in "${folders[@]}"; do
  if ! note_exists "${PROJECT}/${folder}/.gitkeep.md"; then
    "$OBSIDIAN" write "${PROJECT}/${folder}/.gitkeep.md" "placeholder" >/dev/null 2>&1
    created=$((created + 1))
  fi
done

# Write metadata (only if missing)
if [[ "$metadata_exists" == false ]]; then
  metadata="---
project: ${PROJECT}"
  if [[ -n "$REPO_URL" ]]; then
    metadata="${metadata}
repo: ${REPO_URL}"
  fi
  metadata="${metadata}
---

# ${PROJECT}
"
  "$OBSIDIAN" write "${PROJECT}/${PROJECT}_metadata.md" "$metadata" >/dev/null 2>&1
  created=$((created + 1))
fi

# Write architecture overview stub (only if missing)
if ! note_exists "${PROJECT}/Architecture/${PROJECT}_overview.md"; then
  overview="---
tags:
  - architecture
  - ${PROJECT}
project: ${PROJECT}
---

# ${PROJECT} — Architecture Overview
"
  "$OBSIDIAN" write "${PROJECT}/Architecture/${PROJECT}_overview.md" "$overview" >/dev/null 2>&1
  created=$((created + 1))
fi

# Write backlog stub (only if missing)
if ! note_exists "${PROJECT}/Backlog/${PROJECT}_backlog.md"; then
  backlog="---
tags:
  - backlog
  - ${PROJECT}
project: ${PROJECT}
---

# ${PROJECT} — Backlog
"
  "$OBSIDIAN" write "${PROJECT}/Backlog/${PROJECT}_backlog.md" "$backlog" >/dev/null 2>&1
  created=$((created + 1))
fi

if [[ "$created" -eq 0 ]]; then
  echo "Project '${PROJECT}' is up to date. Nothing to create."
else
  echo "Done. Created ${created} notes/folders for '${PROJECT}'."
fi
